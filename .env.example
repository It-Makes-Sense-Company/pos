# Шаблон переменных окружения для Hermes (POS).
# Реальные значения кладём ТОЛЬКО в ~/.hermes/.env (chmod 0600), не сюда.

# --- Инференс (OpenRouter, единый ключ IMS) ---
OPENROUTER_API_KEY=

# --- Telegram ---
# На старте используем тот же бот, что шлёт заявки с itmakessense.co (send-only,
# конфликта с polling нет). Токен — из api/.env сайта.
TELEGRAM_BOT_TOKEN=
# Личный Telegram user_id владельца (DM-only). Пусто = доступ через pairing-код.
TELEGRAM_ALLOWED_USERS=
# Куда доставлять проактивные cron-пинги (по умолчанию — личный DM владельца).
# TELEGRAM_HOME_CHANNEL=

# Модель по умолчанию задаётся в ~/.hermes/config.yaml (model.default),
# на старте — бесплатная (например qwen/...:free). Платные модели — только по
# отдельному разрешению.
